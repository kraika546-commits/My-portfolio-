                <span style={{ fontSize: 10, color: T.muted }}>{k}</span>
                <span style={{ fontSize: 10, color: T.cyan, fontWeight: 600 }}>{v}</span>
              </div>
            ))}
          </div>
        </div>

        {/* ══ RIGHT PANEL — Dashboard ══ */}
        <div style={{ flex: 1, overflowY: "auto", padding: "24px 28px" }}>

          {/* ── Revenue Health ── */}
          <SectionHeader accent={T.cyan}>Revenue Health</SectionHeader>
          <div style={{ display: "grid", gridTemplateColumns: "repeat(3, 1fr)", gap: 12, marginBottom: 28 }}>
            <MetricCard label="Annual Recurring Revenue" value={fmt(calc.arr)} sub="MRR × 12" accent={T.cyan} large delay={0} />
            <MetricCard label="Gross Margin" value={`${fmtNum(calc.grossM)}%`} sub="(MRR − OpCosts) / MRR" badge={b_grossM} accent={calc.grossM > 0 ? T.green : T.red} delay={60} />
            <MetricCard label="Monthly Runway" value={isFinite(calc.runway) ? `${fmtNum(calc.runway)} mo` : "∞"} sub="opCosts ÷ (MRR − costs)" accent={T.amber} delay={120} />
          </div>

          {/* ── Customer Economics ── */}
          <SectionHeader accent={T.amber}>Customer Economics</SectionHeader>
          <div style={{ display: "grid", gridTemplateColumns: "repeat(4, 1fr)", gap: 12, marginBottom: 28 }}>
            <MetricCard label="Customer LTV" value={isFinite(calc.ltv) ? fmt(calc.ltv) : "∞"} sub="ARPU ÷ churn" accent={T.cyan} delay={0} />
            <MetricCard label="LTV : CAC Ratio" value={fmtX(calc.ltvCac)} sub="benchmark: 3x+" badge={b_ltvCac} accent={T.amber} delay={60} />
            <MetricCard label="CAC Payback Period" value={isFinite(calc.payback) ? `${fmtNum(calc.payback)} mo` : "∞"} sub="CAC ÷ ARPU" badge={b_payback} accent={T.cyan} delay={120} />
            <MetricCard label="Break-even Customers" value={isFinite(calc.breakEven) ? fmtNum(calc.breakEven, 0) : "∞"} sub="opCosts ÷ ARPU" accent={T.amber} delay={180} />
          </div>

          {/* ── Retention Health ── */}
          <SectionHeader accent={T.green}>Retention</SectionHeader>
          <div style={{ display: "grid", gridTemplateColumns: "repeat(3, 1fr)", gap: 12, marginBottom: 32 }}>
            <MetricCard label="Monthly Churn Rate" value={`${fmtNum(inputs.churn, 2)}%`} sub="% lost monthly" badge={b_churn} accent={inputs.churn < 3 ? T.green : inputs.churn < 7 ? T.yellow : T.red} delay={0} />
            <MetricCard label="Annual Churn Rate" value={`${fmtNum(inputs.churn * 12, 1)}%`} sub="churn × 12" accent={T.muted} delay={60} />
            <MetricCard label="Retention Rate" value={`${fmtNum(100 - inputs.churn, 2)}%`} sub="1 − monthly churn" accent={T.green} delay={120} />
          </div>

          {/* ── Charts ── */}
          <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 20, marginBottom: 28 }}>

            {/* MRR Projection Chart */}
            <div style={{ background: T.bg2, border: `1px solid ${T.border}`, borderRadius: 10, padding: "20px 18px" }}>
              <div style={{ fontSize: 9, letterSpacing: "0.14em", color: T.muted, textTransform: "uppercase", marginBottom: 16, fontWeight: 600 }}>
                MRR 12-Month Projection
              </div>
              <ResponsiveContainer width="100%" height={180}>
                <AreaChart data={calc.projections} margin={{ top: 5, right: 5, left: 0, bottom: 0 }}>
                  <defs>
                    <linearGradient id="mrrGrad" x1="0" y1="0" x2="0" y2="1">
                      <stop offset="5%"  stopColor={T.cyan} stopOpacity={0.25} />
                      <stop offset="95%" stopColor={T.cyan} stopOpacity={0} />
                    </linearGradient>
                  </defs>
                  <CartesianGrid strokeDasharray="3 3" stroke={T.faint} />
                  <XAxis dataKey="month" tick={{ fontSize: 9, fill: T.muted }} axisLine={false} tickLine={false} />
                  <YAxis tick={{ fontSize: 9, fill: T.muted }} axisLine={false} tickLine={false} tickFormatter={v => `$${v/1000}K`} />
                  <Tooltip content={<CustomTooltip />} />
