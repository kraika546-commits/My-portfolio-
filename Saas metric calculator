                </AreaChart>
              </ResponsiveContainer>
            </div>

            {/* Customer Count Projection Chart */}
            <div style={{ background: T.bg2, border: `1px solid ${T.border}`, borderRadius: 10, padding: "20px 18px" }}>
              <div style={{ fontSize: 9, letterSpacing: "0.14em", color: T.muted, textTransform: "uppercase", marginBottom: 16, fontWeight: 600 }}>
                Customer Count Projection
              </div>
              <ResponsiveContainer width="100%" height={180}>
                <BarChart data={calc.projections} margin={{ top: 5, right: 5, left: 0, bottom: 0 }}>
                  <CartesianGrid strokeDasharray="3 3" stroke={T.faint} vertical={false} />
                  <XAxis dataKey="month" tick={{ fontSize: 9, fill: T.muted }} axisLine={false} tickLine={false} />
                  <YAxis tick={{ fontSize: 9, fill: T.muted }} axisLine={false} tickLine={false} />
                  <Tooltip contentStyle={{ background: T.bg3, border: `1px solid ${T.border}`, borderRadius: 6, fontSize: 11 }} cursor={{ fill: T.faint }} />
                  <Bar dataKey="Customers" fill={T.amber} radius={[3, 3, 0, 0]} maxBarSize={24} />
                </BarChart>
              </ResponsiveContainer>
            </div>
          </div>

          {/* ── Unit Economics Horizontal Bar ── */}
          <div style={{ background: T.bg2, border: `1px solid ${T.border}`, borderRadius: 10, padding: "20px 18px", marginBottom: 28 }}>
            <div style={{ fontSize: 9, letterSpacing: "0.14em", color: T.muted, textTransform: "uppercase", marginBottom: 16, fontWeight: 600 }}>
              Unit Economics Comparison — LTV / CAC / ARPU
            </div>
            <ResponsiveContainer width="100%" height={140}>
              <BarChart data={calc.ltvBar} layout="vertical" margin={{ top: 0, right: 24, left: 10, bottom: 0 }}>
                <CartesianGrid strokeDasharray="3 3" stroke={T.faint} horizontal={false} />
                <XAxis type="number" tick={{ fontSize: 9, fill: T.muted }} axisLine={false} tickLine={false} tickFormatter={v => `$${v}`} />
                <YAxis type="category" dataKey="name" tick={{ fontSize: 10, fill: T.text }} axisLine={false} tickLine={false} width={45} />
                <Tooltip contentStyle={{ background: T.bg3, border: `1px solid ${T.border}`, borderRadius: 6, fontSize: 11 }} formatter={v => [`$${v.toLocaleString()}`, ""]} />
                <Bar dataKey="value" radius={[0, 4, 4, 0]} maxBarSize={28}
                  label={{ position: "right", fontSize: 10, fill: T.text, formatter: v => `$${v.toLocaleString()}` }}
                >
                  {calc.ltvBar.map((_, i) => (
                    <rect key={i} fill={[T.amber, T.red, T.cyan][i]} />
                  ))}
                </Bar>
              </BarChart>
            </ResponsiveContainer>
          </div>

          {/* ── 3 / 6 / 12 Month Callout Cards ── */}
          <SectionHeader accent={T.amber}>Growth Projections</SectionHeader>
          <div style={{ display: "grid", gridTemplateColumns: "repeat(3, 1fr)", gap: 12, marginBottom: 32 }}>
            {[2, 5, 11].map((mo, i) => {
              const p = calc.projections[mo];
              const labels = ["3-Month", "6-Month", "12-Month"];
              return (
                <div key={mo} className="card-hover fade-up" style={{
                  background: T.bg2, border: `1px solid ${T.border}`,
                  borderRadius: 8, padding: "18px 20px",
                  animationDelay: `${i * 80}ms`,
                  position: "relative", overflow: "hidden",
                }}>
                  <div style={{ position: "absolute", top: 0, left: 0, right: 0, height: 2, background: `linear-gradient(90deg, ${T.amber}, transparent)` }} />
                  <div style={{ fontSize: 9, letterSpacing: "0.14em", color: T.amber, textTransform: "uppercase", marginBottom: 12, fontWeight: 600 }}>
                    {labels[i]}
                  </div>
                  <div style={{ display: "flex", flexDirection: "column", gap: 8 }}>
                    {[
                      { k: "MRR",       v: fmt(p.MRR) },
                      { k: "ARR",       v: fmt(p.ARR) },
                      { k: "Customers", v: p.Customers },
                    ].map(({ k, v }) => (
                      <div key={k} style={{ display: "flex", justifyContent: "space-between" }}>
                        <span style={{ fontSize: 10, color: T.muted }}>{k}</span>
                        <span style={{ fontSize: 11, color: T.text, fontWeight: 600 }}>{v}</span>
                      </div>
                    ))}
                  </div>
                </div>
              );
            })}
          </div>

          {/* ── Benchmark Scorecard Table ── */}
          <SectionHeader accent={T.muted}>Benchmark Scorecard</SectionHeader>
          <div style={{ background: T.bg2, border: `1px solid ${T.border}`, borderRadius: 10, overflow: "hidden", marginBottom: 32 }}>
            {[
              { metric: "LTV:CAC Ratio",     value: fmtX(calc.ltvCac),                                              b: b_ltvCac,  danger: "< 1x",   ok: "1–3x",   good: "3x+"    },
              { metric: "Gross Margin",       value: `${fmtNum(calc.grossM)}%`,                                      b: b_grossM,  danger: "< 40%",  ok: "40–70%", good: "> 70%"  },
              { metric: "Monthly Churn",      value: `${fmtNum(inputs.churn, 2)}%`,                                  b: b_churn,   danger: "> 10%",  ok: "5–10%",  good: "< 5%"   },
              { metric: "CAC Payback Period", value: isFinite(calc.payback) ? `${fmtNum(calc.payback)}mo` : "∞",    b: b_payback, danger: "> 24mo", ok: "12–24mo",good: "< 12mo" },
            ].map((row, i) => (
              <div key={i} style={{
                display: "grid", gridTemplateColumns: "180px 100px 1fr 1fr 1fr 100px",
                alignItems: "center",
                padding: "14px 20px",
                borderBottom: i < 3 ? `1px solid ${T.border}` : "none",
                background: i % 2 === 0 ? "transparent" : T.bg0 + "44",
                gap: 12,
              }}>
                <span style={{ fontSize: 11, color: T.text, fontWeight: 500 }}>{row.metric}</span>
                <span style={{ fontSize: 12, color: T.cyan, fontWeight: 700 }}>{row.value}</span>
                <div style={{ display: "flex", alignItems: "center", gap: 6 }}>
                  <div style={{ width: 6, height: 6, borderRadius: "50%", background: T.red }} />
                  <span style={{ fontSize: 9, color: T.muted }}>{row.danger}</span>
                </div>
                <div style={{ display: "flex", alignItems: "center", gap: 6 }}>
                  <div style={{ width: 6, height: 6, borderRadius: "50%", background: T.yellow }} />
                  <span style={{ fontSize: 9, color: T.muted }}>{row.ok}</span>
                </div>
                <div style={{ display: "flex", alignItems: "center", gap: 6 }}>
                  <div style={{ width: 6, height: 6, borderRadius: "50%", background: T.green }} />
                  <span style={{ fontSize: 9, color: T.muted }}>{row.good}</span>
                </div>
                <div style={{
                  display: "inline-flex", alignItems: "center", justifyContent: "center", gap: 4,
                  padding: "4px 10px",
                  background: row.b.color + "18", border: `1px solid ${row.b.color}44`,
                  borderRadius: 20, fontSize: 9, color: row.b.color, fontWeight: 700,
                  letterSpacing: "0.08em", textTransform: "uppercase",
                }}>
                  <div style={{ width: 5, height: 5, borderRadius: "50%", background: row.b.color }} />
                  {row.b.label}
                </div>
              </div>
            ))}
          </div>

          {/* ── Footer ── */}
          <div style={{
            borderTop: `1px solid ${T.border}`, paddingTop: 16,
            display: "flex", justifyContent: "space-between", alignItems: "center",
          }}>
            <div style={{ fontSize: 9, color: T.faint, letterSpacing: "0.1em" }}>
              ALL CALCULATIONS RUN LOCALLY · NO DATA SENT EXTERNALLY
            </div>
            <div style={{ fontSize: 9, color: T.faint }}>
              SAAS METRICS INTELLIGENCE v1.0
            </div>
          </div>

        </div>
      </div>
    </>
  );
}
